.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 角色切换区域 */
.role-switch {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #eee;
}

.role-button {
  flex: 1;
  height: 80rpx;
  margin: 0 10rpx;
  background-color: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.role-button.active {
  background-color: #1890ff;
  color: white;
}

/* 聊天区域样式 */
.chat-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 30rpx;
  display: flex;
}

/* 用户消息样式 */
.user-message {
  justify-content: flex-end;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1890ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 20rpx;
}

.user-content {
  background-color: #1890ff;
  color: white;
}

/* AI消息样式 */
.ai-message {
  justify-content: flex-start;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.ai-content {
  background-color: white;
  color: #333;
}

.message-content {
  max-width: 60%;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 语音按钮样式 */
.audio-button {
  background-color: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
  border: none;
}

/* 输入区域样式 */
.input-container {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #eee;
}

.input-box {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.send-button {
  width: 120rpx;
  height: 80rpx;
  margin-left: 20rpx;
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
}